<?xml version="1.0" encoding="utf-8"?>
<doctrine-mapping xmlns="http://doctrine-project.org/schemas/orm/doctrine-mapping"
                  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                  xsi:schemaLocation="http://doctrine-project.org/schemas/orm/doctrine-mapping https://doctrine-project.org/schemas/orm/doctrine-mapping.xsd">
    <entity name="EntretienProfessionnel\Entity\Db\CampagneAgentStatut" table="entretienprofessionnel_campagne_agent_statut">

        <id name="id" type="integer" column="id">
            <generator strategy="IDENTITY"/>
        </id>
        <many-to-one target-entity="EntretienProfessionnel\Entity\Db\Campagne" field="campagne">
            <join-column name="campagne_id"/>
        </many-to-one>
        <many-to-one target-entity="Structure\Entity\Db\Structure" field="structure">
            <join-column name="structure_id"/>
        </many-to-one>
        <many-to-one target-entity="Agent\Entity\Db\Agent" field="agent">
            <join-column name="agent_id" referenced-column-name="c_individu"/>
        </many-to-one>
        <many-to-one target-entity="EntretienProfessionnel\Entity\Db\EntretienProfessionnel" field="entretienProfessionnel">
            <join-column name="entretienprofessionnel_id" referenced-column-name="id"/>
        </many-to-one>
        <field name="statut" length="1024" column="statut"/>
        <field name="raison" type="text" column="raison"/>
        <field name="refreshDate" type="datetime" column="date_refresh"/>

    </entity>
</doctrine-mapping>
