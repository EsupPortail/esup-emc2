<?xml version="1.0" encoding="utf-8"?>
<doctrine-mapping xmlns="http://doctrine-project.org/schemas/orm/doctrine-mapping"
                  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                  xsi:schemaLocation="http://doctrine-project.org/schemas/orm/doctrine-mapping https://doctrine-project.org/schemas/orm/doctrine-mapping.xsd">
    <entity name="EntretienProfessionnel\Entity\Db\CampagneProgressionStructure" table="entretienprofessionnel_campagne_progression">

        <id name="id" type="integer" column="id">
            <generator strategy="IDENTITY"/>
        </id>
        <many-to-one target-entity="EntretienProfessionnel\Entity\Db\Campagne" field="campagne">
            <join-column name="campagne_id"/>
        </many-to-one>
        <many-to-one target-entity="Structure\Entity\Db\Structure" field="structure">
            <join-column name="structure_id"/>
        </many-to-one>

        <field name="nbTotal" type="integer" column="nb_total"/>
        <field name="nbComplet" type="integer" column="nb_complet"/>
        <field name="nbAutorite" type="integer" column="nb_autorite"/>
        <field name="nbObservation" type="integer" column="nb_observation"/>
        <field name="nbSuperieur" type="integer" column="nb_superieur"/>
        <field name="nbPlanifier" type="integer" column="nb_planifier"/>
        <field name="nbManquant" type="integer" column="nb_manquant"/>

        <field name="date" type="datetime" column="date_refresh"/>

        <!-- HISTORISATION ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~ -->
        <field name="histoCreation" type="datetime" column="histo_creation"/>
        <field name="histoModification" type="datetime" column="histo_modification"/>
        <field name="histoDestruction" type="datetime" column="histo_destruction" nullable="true"/>
        <many-to-one target-entity="UnicaenUtilisateur\Entity\Db\User" field="histoCreateur">
            <join-column name="histo_createur_id" referenced-column-name="ID"/>
        </many-to-one>
        <many-to-one target-entity="UnicaenUtilisateur\Entity\Db\User" field="histoModificateur">
            <join-column name="histo_modificateur_id" referenced-column-name="ID"/>
        </many-to-one>
        <many-to-one target-entity="UnicaenUtilisateur\Entity\Db\User" field="histoDestructeur">
            <join-column name="histo_destructeur_id" referenced-column-name="ID"/>
        </many-to-one>
    </entity>
</doctrine-mapping>
